# .easignore replaces .gitignore for EAS archive packaging.
# Keep all .gitignore rules here, then add build-only excludes below.
# https://expo.fyi/eas-build-archive

# --- from .gitignore ---

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env.local
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Auth Secret
google-auth-client-secret.json

# --- EAS-only: not needed for the build ---

docs/
.cursor/
.vscode/
assets/branding/
assets/images/
