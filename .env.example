# ──────────────────────────────────────────────
# GainGang — environment variables
#
# Client-side public vars (EXPO_PUBLIC_ prefix)
# These are bundled into the app and safe to expose.
# ──────────────────────────────────────────────

# TODO: Decide on the GainGang backend/auth provider.
# The boilerplate ships with Supabase (auth + Postgres + realtime), which fits
# GainGang's needs (users, groups, daily goals, encouragement feed). If you keep
# Supabase, fill in the values below. If you switch providers, update lib/supabase.ts
# and context/auth-context.tsx accordingly.

# Supabase project URL (Settings → API → Project URL)
EXPO_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co

# Supabase anon/public key (Settings → API → anon public)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Local debug helpers (optional) ──
# These are only used to show quick-login buttons on the sign-in screen.
# Do not commit real passwords. Put secrets in `.env.local` instead.
EXPO_PUBLIC_TEST_LOGIN_1_EMAIL=
EXPO_PUBLIC_TEST_LOGIN_1_PASSWORD=
EXPO_PUBLIC_TEST_LOGIN_2_EMAIL=
EXPO_PUBLIC_TEST_LOGIN_2_PASSWORD=

# ── Google sign-in (Supabase Dashboard setup) ──
# 1. Authentication → Providers → Google → enable, add Web client ID + secret
# 2. Authentication → URL Configuration → add redirect URLs:
#    - gaingang://auth/callback
#    - (dev) log [Auth] OAuth redirect URI from Metro when tapping Continue with Google
# 3. Google Cloud Console → OAuth client (Web) → authorized redirect URI =
#    https://<project-ref>.supabase.co/auth/v1/callback
